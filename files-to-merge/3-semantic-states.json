{
	"Semantic/States": {
		"disabled": {
			"filled": {
				"$type": "number",
				"$value": {
					"Light": 46,
					"Dark": 46
				}
			},
			"nonfilled": {
				"$type": "number",
				"$value": {
					"Light": 26,
					"Dark": 26
				}
			}
		},
		"_state-base": {
			"hover":     { "$type": "number", "$value": 0.04  },
			"focus":     { "$type": "number", "$value": 0.12 },
			"activated": { "$type": "number", "$value": 0.12 },
			"ripple":    { "$type": "number", "$value": 0.25 }
		},
		"state-opacity": {
			"flat": {
				"hover": {
					"$type": "number",
					"$value": {
						"Light": "{_state-base.hover} * 2 * 100",
						"Dark": "{_state-base.hover} * 1 * 100"
					}
				},
				"focus": {
					"$type": "number",
					"$value": {
						"Light": "{_state-base.focus} * 2 * 100",
						"Dark": "{_state-base.focus} * 1 * 100"
					}
				},
				"pressed": {
					"$type": "number",
					"$value": {
						"Light": "(1 - (1 - {_state-base.hover} * 2) * (1 - {_state-base.ripple} * 2)) * 100",
						"Dark":  "(1 - (1 - {_state-base.hover} * 1) * (1 - {_state-base.ripple} * 1)) * 100"
					}
				}
			},
			"tonal": {
				"hover": {
					"$type": "number",
					"$value": {
						"Light": "{_state-base.hover} * 1 * 100",
						"Dark": "{_state-base.hover} * 1 * 100"
					}
				},
				"focus": {
					"$type": "number",
					"$value": {
						"Light": "{_state-base.focus} * 1 * 100",
						"Dark": "{_state-base.focus} * 1 * 100"
					}
				},
				"pressed": {
					"$type": "number",
					"$value": {
						"Light": "(1 - (1 - {_state-base.hover}) * (1 - {_state-base.ripple})) * 100",
						"Dark":  "(1 - (1 - {_state-base.hover}) * (1 - {_state-base.ripple})) * 100"
					}
				}
			},
			"outlined-text": {
				"hover": {
					"$type": "number",
					"$value": {
						"Light": "{_state-base.hover} * 1 * 100",
						"Dark": "{_state-base.hover} * 1 * 100"
					}
				},
				"focus": {
					"$type": "number",
					"$value": {
						"Light": "{_state-base.focus} * 1 * 100",
						"Dark": "{_state-base.focus} * 1 * 100"
					}
				},
				"pressed": {
					"$type": "number",
					"$value": {
						"Light": "(1 - (1 - {_state-base.hover}) * (1 - {_state-base.ripple})) * 100",
						"Dark": "(1 - (1 - {_state-base.hover}) * (1 - {_state-base.ripple})) * 100"
					}
				}
			}
		}
	}
}